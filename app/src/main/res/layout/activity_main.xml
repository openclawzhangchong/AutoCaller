<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自动拨号器"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF000000"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 配置区 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="呼叫配置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FFCCCCCC"
            android:layout_marginBottom="16dp" />

        <!-- 电话号码 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="电话号码"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="phone"
            android:hint="请输入电话号码"
            android:background="@drawable/edit_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 拨打次数 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="拨打次数"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/etCallCount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="1"
            android:background="@drawable/edit_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 每次通话时长 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="每次通话时长（秒）"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/etDuration"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="10"
            android:background="@drawable/edit_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 呼叫间隔 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="两次呼叫间隔（秒）"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/etInterval"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="5"
            android:background="@drawable/edit_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="24dp" />

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:text="开始呼叫"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:text="停止"
                android:textSize="16sp"
                android:enabled="false" />
        </LinearLayout>

        <!-- 状态区 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="运行状态"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FFCCCCCC"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="状态：空闲"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="就绪"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:paddingBottom="12dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 / 0"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- 重要提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ 重要提示"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFE65100"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自动挂断需要开启无障碍服务。请在系统设置中搜索「无障碍」，找到「自动拨号器」并开启开关。"
            android:textSize="13sp"
            android:textColor="#FF666666"
            android:lineSpacingExtra="3dp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btnOpenAccessibility"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="去开启无障碍服务"
            android:textSize="14sp"
            style="@style/Widget.AppCompat.Button.Borderless" />

    </LinearLayout>

</ScrollView>